import json
import os
class Student:
    def __init__(self, student_id: int, name: str, age: int):
        self.id = student_id
        self.name = name
        self.age = age

    def to_dict(self):
        return {
            "id": self.id,
            "name": self.name,
            "age": self.age
        }



class StudentManager:
    def __init__(self, filename="students.json"):
        self.filename = filename
        self.students = []

    def load_from_file(self):
        if not os.path.exists(self.filename):
            with open(self.filename, "w", encoding="utf-8") as f:
                json.dump([], f)

        # загрузка данных
        with open(self.filename, "r", encoding="utf-8") as f:
            data = json.load(f)
            self.students = [
                Student(item["id"], item["name"], item["age"])
                for item in data
            ]

    def save_to_file(self):
        with open(self.filename, "w", encoding="utf-8") as f:
            json.dump([s.to_dict() for s in self.students], f, indent=4)

    def add_student(self):
        try:
            student_id = int(input("Введите ID: "))

            # проверка уникальности ID
          for s in self.students:
                if s.id == student_id:
                    print("Студент с таким ID уже существует")
                    return

            name = input("Введите имя: ")
            age = int(input("Введите возраст: "))

            new_student = Student(student_id, name, age)
            self.students.append(new_student)

            print("Студент добавлен")

        except ValueError:
            print("l Ошибка ввода!")

    def show_students(self):
        if not self.students:
            print("Список студентов пуст.")
            return

        print("Список студентов:")
        for s in self.students:
            print(f"ID: {s.id}, Имя: {s.name}, Возраст: {s.age}")


# меню
def show_menu():
    print("\nМеню:")
    print("1. Показать студентов")
    print("2. Добавить студента")
    print("3. Сохранить в файл")
    print("0. Выход")


# главное
def main():
    manager = StudentManager()
    manager.load_from_file()

    while True:
        show_menu()
        choice = input("Выберите пункт: ")

        if choice == "1":
            manager.show_students()
        elif choice == "2":
            manager.add_student()
        elif choice == "3":
            manager.save_to_file()
            print("Данные сохранены")
        elif choice == "0":
            manager.save_to_file()
            print("Выход... Данные сохранены.")
            break
        else:
            print("Неверный выбор")


if __name__ == "__main__":
    main()
